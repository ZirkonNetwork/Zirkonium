     });
 
     public static record Favicon(byte[] iconBytes) {
@@ -62,4 +62,21 @@ public record ServerStatus(Component description, Optional<ServerStatus.Players>
             return new ServerStatus.Version(worldVersion.getName(), worldVersion.getProtocolVersion());
         }
     }
-}
+
+    // Zirkonium start - No Chat Reports
+    private static boolean preventsChatReports;
+
+    @Override
+    public boolean enforcesSecureChat() {
+        return me.elephant1214.zirkonium.configuration.ZirkoniumConfig.NoChatReports.noChatReports || this.enforcesSecureChat;
+    }
+
+    public boolean preventsChatReports() {
+        return (this.version.isPresent() && this.version.get().protocol < 759 && this.version.get().protocol > 0) || preventsChatReports;
+    }
+
+    public void setPreventsChatReports(boolean prevents) {
+        preventsChatReports = prevents;
+    }
+    // Zirkonium end
+}
\ No newline at end of file
