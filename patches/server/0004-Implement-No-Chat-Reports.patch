diff --git a/src/main/java/nathan/zirkonium/configuration/ZirkoniumConfig.java b/src/main/java/nathan/zirkonium/configuration/ZirkoniumConfig.java
index 7410c70a0ebff81ce5644e6224b5b30d4a3e60ac..b9114a6dedcc7a9f8b246e69db7504cba95d34a6 100644
--- a/src/main/java/nathan/zirkonium/configuration/ZirkoniumConfig.java
+++ b/src/main/java/nathan/zirkonium/configuration/ZirkoniumConfig.java
@@ -40,6 +40,8 @@ public class ZirkoniumConfig {
     }
 
     static void readConfig() {
+        NoChatReports.noChatReportsSettings();
+
         try {
             config.save(CONFIG_FILE);
         } catch (IOException ex) {
@@ -66,7 +68,15 @@ public class ZirkoniumConfig {
         return config.getInt(path, config.getInt(path));
     }
 
-    public static class Gameplay {
-        public static int maxAnvilLevelCost = 40;
+    public static class NoChatReports {
+        public static boolean noChatReports = true;
+        public static boolean addQueryData = true;
+        public static boolean convertToSystemMessage = true;
+
+        public static void noChatReportsSettings() {
+            noChatReports = getBoolean("no-chat-reports.enabled", noChatReports);
+            addQueryData = getBoolean("no-chat-reports.addQueryData", addQueryData) && noChatReports;
+            convertToSystemMessage = getBoolean("no-chat-reports.convert-to-system-message", convertToSystemMessage) && noChatReports;
+        }
     }
 }
diff --git a/src/main/java/net/minecraft/network/FriendlyByteBuf.java b/src/main/java/net/minecraft/network/FriendlyByteBuf.java
index 1f4b64a5f812376c499c98cb4be62469bd0b7dbe..8b5899d950b42bee6f9650c84ef1e5ebcfb9b13c 100644
--- a/src/main/java/net/minecraft/network/FriendlyByteBuf.java
+++ b/src/main/java/net/minecraft/network/FriendlyByteBuf.java
@@ -147,18 +147,22 @@ public class FriendlyByteBuf extends ByteBuf {
     public <T> T readJsonWithCodec(Codec<T> codec) {
         JsonElement jsonelement = (JsonElement) GsonHelper.fromJson(FriendlyByteBuf.GSON, this.readUtf(), JsonElement.class);
         DataResult<T> dataresult = codec.parse(JsonOps.INSTANCE, jsonelement);
-
-        return Util.getOrThrow(dataresult, (s) -> {
-            return new DecoderException("Failed to decode json: " + s);
-        });
+        // Zirkonium start - No Chat Reports
+        T result = Util.getOrThrow(dataresult, (s) -> new DecoderException("Failed to decode json: " + s));
+        if (nathan.zirkonium.configuration.ZirkoniumConfig.NoChatReports.addQueryData && jsonelement.getAsJsonObject().has("preventsChatReports"))
+            ((net.minecraft.network.protocol.status.ServerStatus) result).setPreventsChatReports(jsonelement.getAsJsonObject().get("preventsChatReports").getAsBoolean());
+        return result;
+        // Zirkonium end
     }
 
     public <T> void writeJsonWithCodec(Codec<T> codec, T value) {
         DataResult<JsonElement> dataresult = codec.encodeStart(JsonOps.INSTANCE, value);
-
-        this.writeUtf(FriendlyByteBuf.GSON.toJson((JsonElement) Util.getOrThrow(dataresult, (s) -> {
-            return new EncoderException("Failed to encode: " + s + " " + value);
-        })));
+        // Zirkonium start - No Chat Reports
+        JsonElement element = Util.getOrThrow(dataresult, (s) -> new EncoderException("Failed to encode: " + s + " " + value));
+        if (nathan.zirkonium.configuration.ZirkoniumConfig.NoChatReports.addQueryData && codec == net.minecraft.network.protocol.status.ServerStatus.CODEC)
+            element.getAsJsonObject().addProperty("preventsChatReports", true);
+        this.writeUtf(FriendlyByteBuf.GSON.toJson(element));
+        // Zirkonium end
     }
 
     public <T> void writeId(IdMap<T> registry, T value) {
