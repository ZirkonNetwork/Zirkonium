From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Elephant1214 <nathangetsmail@gmail.com>
Date: Sat, 24 Dec 2022 17:16:04 -0700
Subject: [PATCH] Implement a configurable maximum enchantment level multiplier


diff --git a/src/main/java/nathan/zirkonium/configuration/ZirkoniumConfig.java b/src/main/java/nathan/zirkonium/configuration/ZirkoniumConfig.java
index b9114a6dedcc7a9f8b246e69db7504cba95d34a6..d23c1f0ebfabbcffd445f19f10ef8f2a83dbcefa 100644
--- a/src/main/java/nathan/zirkonium/configuration/ZirkoniumConfig.java
+++ b/src/main/java/nathan/zirkonium/configuration/ZirkoniumConfig.java
@@ -40,6 +40,7 @@ public class ZirkoniumConfig {
     }
 
     static void readConfig() {
+        Gameplay.gameplaySettings();
         NoChatReports.noChatReportsSettings();
 
         try {
@@ -68,6 +69,19 @@ public class ZirkoniumConfig {
         return config.getInt(path, config.getInt(path));
     }
 
+    public static class Gameplay {
+        public static int maxEnchantLevelMultiplier = 1;
+
+        public static void gameplaySettings() {
+            maxEnchantLevelMultiplier = getInt("gameplay.enchantment.maxLevelMultiplier", maxEnchantLevelMultiplier);
+            if (maxEnchantLevelMultiplier < 1) {
+                log(Level.WARNING, "The maximum enchantment level multiplier can not be less than 1, resetting it.");
+                maxEnchantLevelMultiplier = 1;
+                set("gameplay.enchantment.maxLevelMultiplier", 1);
+            }
+        }
+    }
+
     public static class NoChatReports {
         public static boolean noChatReports = true;
         public static boolean addQueryData = true;
